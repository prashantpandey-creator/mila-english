# Generated by Void Manifest Engine
# EngFluent — Environment Variables

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/eng_fluent"
JWT_SECRET="change-me-to-a-random-secret"
OPENAI_API_KEY=""
OPENAI_REALTIME_MODEL="gpt-realtime-2.1"
OPENAI_REALTIME_VOICE="shimmer"
OPENAI_ASSESSMENT_MODEL="gpt-5.6-luna"
OPENROUTER_API_KEY=""
# Required before OpenRouter is used. Select a model whose provider terms allow
# every region in which Mila will offer that model.
OPENROUTER_ASSESSMENT_MODEL=""
OPENAI_TRANSLATION_MODEL="gpt-5.6"
# Pretrained, self-hosted companion model. No training is required. Use
# qwen3:1.7b-q4_K_M on machines that cannot comfortably run the 4B model.
LOCAL_LLM_URL="http://127.0.0.1:11434"
LOCAL_LLM_MODEL="qwen3:4b-instruct-2507-q4_K_M"
# Used only by reasoning models such as gpt-oss. Low is the usable default for
# conversational latency; medium/high are better reserved for deliberate work.
LOCAL_LLM_REASONING_EFFORT="low"
# Off by default. Enable only after confirming that every configured provider
# and model is permitted in the learner's region.
ALLOW_EXTERNAL_CHAT_FALLBACK="false"
OPENROUTER_CHAT_MODEL=""
# When Next.js runs outside Docker, point these at locally running services.
PRON_URL="http://localhost:8000"
ASR_URL="http://localhost:8001"
ASR_CPU_THREADS="4"
TELEGRAM_TRANSLATOR_BOT_TOKEN=""
TELEGRAM_WEBHOOK_SECRET=""
