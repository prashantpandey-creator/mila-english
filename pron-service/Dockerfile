FROM python:3.12-slim
RUN apt-get update && apt-get install -y --no-install-recommends espeak-ng ffmpeg \
    && rm -rf /var/lib/apt/lists/*
WORKDIR /app
RUN pip install --no-cache-dir onnxruntime numpy phonemizer soundfile fastapi "uvicorn[standard]" python-multipart
COPY vocab.json model.onnx server.py ./
EXPOSE 8000
CMD ["uvicorn", "server:app", "--host", "0.0.0.0", "--port", "8000"]
